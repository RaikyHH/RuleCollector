# Copy this file to .env and fill in your values.
# Docker Compose picks up .env automatically.

# GitHub personal access token — no special scopes needed for public repos.
# Prevents rate limiting during sync. Takes precedence over tokens in config.json.
GITHUB_TOKEN=your_token_here

# Proxy — uncomment if your network requires one.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1
